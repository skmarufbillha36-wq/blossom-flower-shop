{
  "name": "@flower-shop/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run db:generate && esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --external:@prisma/client --external:bcryptjs --external:cloudinary",
    "start": "node dist/server.js",
    "db:generate": "cd ../../packages/database && npx prisma generate",
    "db:migrate": "cd ../../packages/database && npx prisma migrate deploy",
    "db:seed": "cd ../../packages/database && npx ts-node src/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@flower-shop/database": "*",
    "@flower-shop/types": "*",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "esbuild": "^0.21.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
