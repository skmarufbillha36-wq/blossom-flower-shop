# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/flower_shop"

# ─── JWT ─────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -base64 64)
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ─── Cloudinary (Optional) ───────────────────────────────
# Leave blank to disable image upload functionality
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
